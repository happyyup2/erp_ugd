rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Firebase 내부 관리자 계정입니다. 실제 로그인 화면에는 노출하지 않습니다.
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'admin@ugd-erp.example';
    }

    // 로그인 전 지점 선택 화면에 필요한 공개 정보만 둡니다. PIN·해시값은 포함하지 않습니다.
    match /public_branches/{branchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 지점 설정 및 PIN 관련 데이터는 인증 후에만 읽고, 관리 계정만 변경합니다.
    match /settings/{branchId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // 일일마감 원본 데이터입니다. 공통 지점 PIN 정책이므로 로그인한 사용자가 조회·저장합니다.
    match /daily_settles/{recordId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.recordId is string
        && request.resource.data.master is map
        && request.resource.data.expenses is list
        && request.resource.data.staff is list;
      allow delete: if isAdmin();
    }

    match /staff_rosters/{branchId} {
      allow read, write: if signedIn();
    }

    match /branch_own_rosters/{branchId} {
      allow read, write: if signedIn();
    }

    match /shared_data/{dataKey} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
